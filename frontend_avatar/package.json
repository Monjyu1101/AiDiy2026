{
  "name": "frontend-avatar",
  "private": true,
  "version": "0.1.0",
  "description": "Vue 3 + TypeScript + Vite + Electron desktop app base",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "concurrently -k \"npm:dev:main\" \"npm:dev:run\"",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:run": "wait-on tcp:127.0.0.1:8099 file:dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:8099 node electron/dev-filter.cjs dist-electron/main.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vue-tsc --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "start": "electron dist-electron/main.js",
    "type-check": "vue-tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.4.2",
    "@pixiv/three-vrm-animation": "^3.4.2",
    "axios": "^1.13.1",
    "monaco-editor": "^0.55.1",
    "three": "^0.179.1",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.10.3",
    "electronmon": "^2.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vue-tsc": "^3.2.2",
    "wait-on": "^8.0.5"
  }
}
